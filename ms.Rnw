    n_obs = paste0("N = ", N),
    n_units = paste0("U = ", U)
  ) %>%
  select(-COOLING_TYPE, -J, -M, -BLOCK, -COOLING, -(ll_2:ll_50)) %>%
  rename(ll_max = ll_1) %>%
  group_by(n_units, seed = data_seed) %>%
  summarize(
    ll_max = max(ll_max),
    ll_min = min(ll_max)
